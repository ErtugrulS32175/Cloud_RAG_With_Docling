# --- Database ---
PG_DSN=postgresql://rag:CHANGE_ME@localhost:5433/ragdb
OUTPUT_DIR=./output
UPLOAD_DIR=./data/uploads

# --- Embedding + reranker (vLLM, OpenAI-compatible) ---
EMBED_API_URL=http://localhost:8011/v1/embeddings
EMBED_MODEL_NAME=BAAI/bge-m3
RERANK_API_URL=http://localhost:8002/v1/score
RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3

# --- LLM (any OpenAI-compatible chat endpoint; swap freely by URL) ---
LLM_API_URL=http://localhost:8000/v1/chat/completions
LLM_MODEL_NAME=Qwen/Qwen3-14B

# --- OCR service ---
# router.py uploads images to services over multipart/form-data, so services can
# live off-box (a container, a remote GPU host) -- just point the URL at the host.
PADDLE_OCR_URL=http://127.0.0.1:8100/ocr
SERVICE_TIMEOUT=120

# --- Pluggable table backends (same POST-image -> {tables:[...]} contract) ----
# Point each URL where the service runs (local or a remote GPU tunnel). The
# pipeline (preprocess/verify/validate/export) is engine-agnostic.
TATR_TABLE_URL=http://127.0.0.1:8102/table
DOCLING_TABLE_URL=http://127.0.0.1:8103/table_tr
GEMMA_TABLE_URL=http://127.0.0.1:8101/table
PADDLEOCR_VL_URL=http://127.0.0.1:8104/table
HUNYUAN_TABLE_URL=http://127.0.0.1:8105/table

# Single-backend mode: tatr | docling | gemma | paddleocr_vl | hunyuan
TABLE_BACKEND=paddleocr_vl
# Two-model consensus mode (primary,secondary) -- cross-checks two readings.
CONSENSUS_BACKENDS=paddleocr_vl,hunyuan
# Columns tatr reads as Turkish text (EasyOCR-tr) instead of digits (PaddleOCR).
TATR_TEXT_COLS=1

# Image enhancement (deskew+contrast+upscale) is owned by the pipeline, so run
# backend services with PREPROCESS=0 to avoid double-enhancing.
PREPROCESS=1
# Tables with confidence <= this, OR any validation issue / model disagreement,
# are flagged needs_review for a human to check.
TABLE_REVIEW_THRESHOLD=0.9
