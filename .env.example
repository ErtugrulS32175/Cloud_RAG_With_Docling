PG_DSN=postgresql://rag:CHANGE_ME@localhost:5433/ragdb
PDF_PATH=./data/2024.pdf
OUTPUT_DIR=./output
EMBED_API_URL=http://localhost:8011/v1/embeddings
EMBED_MODEL_NAME=BAAI/bge-m3
GRANITE_API_URL=http://localhost:8003/v1/chat/completions
RERANK_API_URL=http://localhost:8002/v1/score
RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3
# LLM_API_URL/LLM_MODEL_NAME point at whatever OpenAI-compatible chat
# endpoint is currently serving the LLM role -- swap freely between the
# RunPod Qwen3-14B server (LLM_API_URL=http://localhost:8000/...) and the
# local services/llm_service.py (below) without changing any pipeline code.
LLM_API_URL=http://localhost:8102/v1/chat/completions
LLM_MODEL_NAME=google/gemma-4-E4B-it
# Only read by services/llm_service.py itself (the local Gemma chat service).
LLM_SERVICE_MODEL=google/gemma-4-E4B-it
# Only read by services/gemma_service.py itself (the table/image-extraction
# service). All roles use E4B for this trial (one capable stand-in for chat +
# tables). Gemma is a dev stand-in only: production LLM = GPT-OSS-120B (text-
# only), so the real deliverable is the *table VLM* -- PaddleOCR-VL / HunyuanOCR
# -- that feeds it. E4B > E2B for tables (OmniDocBench 0.181 < 0.290, lower=better).
GEMMA_TABLE_MODEL=google/gemma-4-E4B-it
UPLOAD_DIR=./data/uploads
# router.py uploads images to these services via multipart/form-data, so they
# can live off-box (RunPod, a container, another host) -- just point the URL at
# the tunnel/host. SERVICE_TIMEOUT (seconds) covers slower remote round-trips.
PADDLE_OCR_URL=http://127.0.0.1:8100/ocr
SERVICE_TIMEOUT=120
# --- Pluggable table backends (services with the same POST-image contract) ----
# Point each URL where the service runs (local or a RunPod/H200 tunnel). Switch
# engines with TABLE_BACKEND -- the pipeline (preprocess/verify/validate/export)
# is engine-agnostic. VLM backends handle varied/complex formats; tatr is the
# frugal deterministic engine.
GEMMA_TABLE_URL=http://127.0.0.1:8101/table
TATR_TABLE_URL=http://127.0.0.1:8102/table
DOCLING_TABLE_URL=http://127.0.0.1:8103/table_tr
PADDLEOCR_VL_URL=http://127.0.0.1:8104/table
HUNYUAN_TABLE_URL=http://127.0.0.1:8105/table
# tatr | docling | gemma | paddleocr_vl | hunyuan
TABLE_BACKEND=tatr
# Columns tatr_service reads with EasyOCR-tr (Turkish text) instead of
# PaddleOCR digits (comma-separated indices; default the name column).
TATR_TEXT_COLS=1
# OCR image-enhancement (deskew+contrast+upscale). The table_pipeline owns this,
# so run backend services with PREPROCESS=0 to avoid double-enhancing.
PREPROCESS=1
# Tables with confidence <= this (or any validation issue) are copied to
# output/tables/_review/ and marked needs_review for a human to check.
TABLE_REVIEW_THRESHOLD=0.9


